{
  "rules": {
    "rooms": {
      "$code": {
        ".write": "auth != null && !data.exists()",
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || root.child('rooms').child($code).child('players').child(auth.uid).exists())"
        },
        "players": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('rooms').child($code).child('players').child(auth.uid).exists()",
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('rooms').child($code).child('players').child(auth.uid).exists())"
          }
        },
        "round": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('rooms').child($code).child('players').child(auth.uid).exists()",
          "votes": {
            "$uid": {
              ".write": "auth != null && ($uid === auth.uid || root.child('rooms').child($code).child('players').child(auth.uid).exists())"
            }
          }
        }
      }
    },
    "privateWords": {
      "$code": {
        ".write": "auth != null && root.child('rooms').child($code).child('players').child(auth.uid).exists()",
        "$uid": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && $uid === auth.uid && !newData.exists()"
        }
      }
    },
    "pairReveals": {
      "$code": {
        ".write": "auth != null && root.child('rooms').child($code).child('players').child(auth.uid).exists()",
        ".read": "auth != null && root.child('rooms').child($code).child('meta').child('phase').val() === 'result'"
      }
    }
  }
}
